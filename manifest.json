{
  "manifest_version": 3,
  "name": "Unswitch",
  "description": "Lock yourself into one tab. Tab lock toggle and pomodoro focus timer with escalating breaks.",
  "version": "1.0.0",
  "permissions": ["tabs", "activeTab", "scripting", "alarms", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/blocker.js"],
      "css": ["content/blocker.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-unlocked-16.png",
      "32": "icons/icon-unlocked-32.png",
      "48": "icons/icon-unlocked-48.png",
      "128": "icons/icon-unlocked-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-unlocked-16.png",
    "32": "icons/icon-unlocked-32.png",
    "48": "icons/icon-unlocked-48.png",
    "128": "icons/icon-unlocked-128.png"
  }
}
